{
  "name": "env-guard",
  "version": "0.1.0",
  "description": "Type-safe environment variable validation and parsing with zero dependencies",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "env",
    "environment",
    "variables",
    "validation",
    "type-safe",
    "typescript",
    "config",
    "process-env",
    "dotenv",
    "zero-dependency"
  ],
  "author": "yogeshwaran-c",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yogeshwaran-c/env-guard.git"
  },
  "homepage": "https://github.com/yogeshwaran-c/env-guard#readme",
  "bugs": {
    "url": "https://github.com/yogeshwaran-c/env-guard/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
